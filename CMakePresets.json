{
  "version": 6,
  "configurePresets": [
    {
      "name": "windows-msvc-debug",
      "displayName": "Windows MSVC Debug",
      "generator": "Visual Studio 16 2019",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build/windows-msvc-debug",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "ENGINE_BUILD_TESTS": "ON"
      }
    },
    {
      "name": "windows-msvc-release",
      "inherits": "windows-msvc-debug",
      "binaryDir": "${sourceDir}/build/windows-msvc-release",
      "cacheVariables": {}
    }
  ],
  "buildPresets": [
    { "name": "debug", "configurePreset": "windows-msvc-debug", "configuration": "Debug" },
    { "name": "release", "configurePreset": "windows-msvc-release", "configuration": "Release" }
  ],
  "testPresets": [
    { "name": "debug", "configurePreset": "windows-msvc-debug", "configuration": "Debug", "output": { "outputOnFailure": true } }
  ]
}
