{
  "schemaVersion": 1,
  "id": "inventory",
  "designResolution": [1920, 1080],
  "widgets": [
    {
      "id": "inventory_dim",
      "type": "panel",
      "anchor": "center",
      "offset": [0, 0],
      "size": [1920, 1080],
      "opacity": 0.7,
      "color": [21, 23, 25, 255]
    },
    {
      "id": "inventory_panel",
      "type": "panel",
      "anchor": "center",
      "offset": [0, 0],
      "size": [720, 520],
      "color": [45, 41, 35, 250]
    },
    {
      "id": "inventory_title",
      "type": "text",
      "anchor": "center",
      "offset": [0, -210],
      "size": [480, 56],
      "bind": "inventory.title",
      "text": "Inventory",
      "textAlign": "center",
      "textVAlign": "middle",
      "fontSize": 44,
      "color": [241, 238, 232, 255]
    },
    {
      "id": "inventory_hint",
      "type": "text",
      "anchor": "center",
      "offset": [0, -20],
      "size": [560, 80],
      "bind": "inventory.hint",
      "text": "I to close · weight 12 / 40",
      "textAlign": "center",
      "textVAlign": "middle",
      "fontSize": 24,
      "color": [155, 163, 167, 255]
    },
    {
      "id": "inventory_close",
      "type": "button",
      "anchor": "center",
      "offset": [0, 180],
      "size": [240, 48],
      "bind": "inventory.close",
      "text": "Close",
      "textAlign": "center",
      "textVAlign": "middle",
      "fontSize": 30,
      "color": [213, 185, 120, 255]
    }
  ]
}
